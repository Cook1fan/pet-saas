# 后端环境变量配置
# 复制此文件为 .env 并填入真实值

# 数据库
DB_URL=jdbc:mysql://localhost:3306/pet_saas?useUnicode=true&characterEncoding=utf-8&serverTimezone=Asia/Shanghai&useSSL=false
DB_USERNAME=root
DB_PASSWORD=your_password

# Redis
REDIS_HOST=localhost
REDIS_PORT=7000
REDIS_PASSWORD=your_password

# RabbitMQ
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=guest
RABBITMQ_PASSWORD=your_password

# AI API
AI_API_KEY=your_ai_api_key

# 微信小程序
WX_MINIAPP_APPID=your_miniapp_appid
WX_MINIAPP_SECRET=your_miniapp_secret
WX_MINIAPP_TOKEN=your_token
WX_MINIAPP_AES_KEY=your_aes_key

# 微信公众号
WX_MP_APPID=your_mp_appid
WX_MP_SECRET=your_mp_secret
WX_MP_TOKEN=your_mp_token
WX_MP_AES_KEY=your_mp_aes_key
WX_MP_CALLBACK_URL=https://your-domain.com/api/mp/wx/callback
WX_MP_REGISTER_TEMPLATE_ID=your_template_id

# 阿里云OSS
ALIYUN_OSS_ENDPOINT=https://oss-cn-shanghai.aliyuncs.com
ALIYUN_OSS_BUCKET=your_bucket
ALIYUN_OSS_ACCESS_KEY_ID=your_access_key_id
ALIYUN_OSS_ACCESS_KEY_SECRET=your_access_key_secret
ALIYUN_OSS_CDN_DOMAIN=